# LiteLLM proxy endpoint — all model requests route through here by default
LITELLM_API_BASE=http://localhost:4000/v1

# OTEL trace exporter — point at Jaeger, Arize Phoenix, or Grafana Alloy
# Optional: if unset, traces are still emitted but may be silently dropped
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317/v1/traces

# Optional: direct routing to named Ollama instances (multi-GPU setups)
# Use model prefix "ws/<model>" to route to OLLAMA_WS_URL
# Use model prefix "sre/<model>" to route to OLLAMA_SRE_URL
# If unset, both default to localhost:11434
# OLLAMA_WS_URL=http://workstation:11434
# OLLAMA_SRE_URL=http://secondary-gpu-node:11434

# Optional: Prometheus Pushgateway for score/latency metrics per run
# If unset, metric pushing is skipped — eval results are still written to results/
# PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9092
